{
  "manifest_version": 3,
  "name": "TwoYen",
  "version": "1.0",
  "description": "Scrape ASINs and update Featured Offer Prices",
  "permissions": [
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://www.amazon.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Run Scraper"
  }
}
